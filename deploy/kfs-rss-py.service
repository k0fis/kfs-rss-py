[Unit]
Description=kfs-rss-py backend (Flask/Gunicorn)
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
WorkingDirectory=/opt/rss-backend-py
ExecStart=/opt/rss-backend-py/venv/bin/gunicorn -b 127.0.0.1:8180 -w 2 rss_api:app
EnvironmentFile=/opt/idp/jwt-secret.env
Environment=DB_PASSWORD=changeme
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
